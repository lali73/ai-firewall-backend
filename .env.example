# Server
PORT=5000
NODE_ENV=development

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:5173
SERVER_PUBLIC_URL=https://your-backend-domain.com

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# Email OTP via Resend
RESEND_API_KEY=re_your_resend_api_key
# Use a verified sender/domain from Resend
EMAIL_FROM=Acme <onboarding@yourdomain.com>

# Gateway SSH / WireGuard
GATEWAY_HOST=34.173.88.58
GATEWAY_PORT=22
GATEWAY_USERNAME=service-account-user
# Recommended for compact Ed25519/OpenSSH keys stored as base64:
GATEWAY_PRIVATE_KEY_BASE64=base64-encoded-openssh-private-key
# Alternative to GATEWAY_PRIVATE_KEY_BASE64:
# GATEWAY_PRIVATE_KEY=raw-private-key-or-base64-encoded-private-key
# GATEWAY_PRIVATE_KEY_PATH=/absolute/path/to/key
GATEWAY_PUBLIC_IP=34.173.88.58
GATEWAY_WIREGUARD_PUBLIC_KEY=replace-with-gateway-wireguard-public-key
GATEWAY_WIREGUARD_PORT=51820
WIREGUARD_INTERFACE=wg0
WIREGUARD_NETWORK_PREFIX=10.0.0
WIREGUARD_START_HOST=2
WIREGUARD_END_HOST=254
WIREGUARD_DNS=1.1.1.1
WIREGUARD_ALLOWED_IPS=0.0.0.0/0, ::/0

# Gateway alert webhook
ALERT_WEBHOOK_SECRET=replace-with-shared-secret

# Chapa demo/test payments
CHAPA_SECRET_KEY=CHASECK_TEST-vJ3oe4g1614scZRIPjhkOGOJTrcad82g
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_RETURN_URL=http://localhost:5173/payment/chapa/return
CHAPA_CURRENCY=ETB
