# Server
PORT=5000
NODE_ENV=development

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# Email OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password-or-app-password
EMAIL_FROM=your-app@example.com

# Gateway SSH / WireGuard
GATEWAY_HOST=34.173.88.58
GATEWAY_PORT=22
GATEWAY_USERNAME=service-account-user
GATEWAY_PRIVATE_KEY=base64-encoded-openssh-private-key
# Alternative to GATEWAY_PRIVATE_KEY:
# GATEWAY_PRIVATE_KEY_PATH=/absolute/path/to/key
GATEWAY_PUBLIC_IP=34.173.88.58
GATEWAY_WIREGUARD_PUBLIC_KEY=replace-with-gateway-wireguard-public-key
GATEWAY_WIREGUARD_PORT=51820
WIREGUARD_INTERFACE=wg0
WIREGUARD_NETWORK_PREFIX=10.0.0
WIREGUARD_START_HOST=2
WIREGUARD_END_HOST=254
WIREGUARD_DNS=1.1.1.1
WIREGUARD_ALLOWED_IPS=0.0.0.0/0, ::/0

# Gateway alert webhook
ALERT_WEBHOOK_SECRET=replace-with-shared-secret
